# Copia este archivo a `.env` y coloca tu API key de OpenAI.
# OJO: el proyecto usa OPENAI_API_KEY_WORK (no la variable default OPENAI_API_KEY),
# porque así está nombrada tu key en este equipo.
OPENAI_API_KEY_WORK=sk-...

# --- MariaDB (persistencia de consumos) ---
# Misma convención que tus proyectos fastapi-mariadb*. El password va en
# `mariadb_c` (igual que allá). Si la dejas vacía, la API arranca igual pero
# NO guarda (best-effort: loguea un warning y sigue respondiendo).
DB_HOST=tu_host
DB_USER=tu_usuario
mariadb_c=tu_password
DB_NAME=nombre_base_datos
DB_PORT=3306
