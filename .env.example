# Copia este archivo a `.env` y coloca tu API key de OpenAI.
# OJO: el proyecto usa OPENAI_API_KEY_WORK (no la variable default OPENAI_API_KEY),
# porque así está nombrada tu key en este equipo.
OPENAI_API_KEY_WORK=sk-...

# --- Base de datos (persistencia de consumos) ---
# SQLite en un archivo local, sin servidor ni credenciales. Por default vive en
# nutricion.db junto al código; descomenta para guardarlo en otra ruta.
# DB_PATH=./nutricion.db

# --- Solo en producción ---
# Origen del front permitido por CORS (coma-separada si son varios).
# CORS_ORIGINS=https://kcal.moibe.me
